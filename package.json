{
  "name": "binance-polymarket-delay-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Serious modular TypeScript bot for Binance -> Polymarket delay trading on BTC 5m/15m markets.",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/app/main.js",
  "scripts": {
    "dev": "tsx src/app/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/main.js",
    "smoke:shadow": "tsx src/app/smokeShadow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "binance",
    "polymarket",
    "trading",
    "telegram",
    "typescript",
    "sqlite",
    "websocket"
  ],
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^4.21.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.7",
    "ethers": "5.8.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
